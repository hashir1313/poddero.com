---
import Layout from "../layouts/Layout.astro";
import HeroHome from "../components/HeroHome.astro";
import TextMarquee from "../components/TextMarquee.astro";
import GalleryText from "../components/GalleryText.astro";
import ImageMarquee from "../components/ImageMarquee.astro";
import Faqs from "../components/Faqs.astro";
import StepsTimeline from "../components/StepsTimeline.astro";
import Plans from "../components/Plans.astro";
import Statements from "../components/Statements.astro";
import WhyChoseUs from "../components/WhyChoseUs.astro";
import GL from "../components/GL.astro";
import GLPlaces from "../components/GlPlaces.astro";

import logo1 from "../assets/logoipsum-344.svg";
import logo2 from "../assets/logoipsum-350.svg";
import logo3 from "../assets/logoipsum-345.svg";
import logo4 from "../assets/logoipsum-385.svg";
import logo5 from "../assets/logoipsum-375.svg";
import logo6 from "../assets/logoipsum-378.svg";
import logo7 from "../assets/logoipsum-346.svg";
import logo8 from "../assets/logoipsum-331.svg";
---

<Layout title="Home">
  <HeroHome
    title="Launch, Grow, Scale"
    subtitle="From professional editing and publishing to distribution and marketing, We handle it all."
    cta={{
      title: "Book a Consultation",
      url: "#",
    }}
  />

  <WhyChoseUs
    title="Why Choose Podderro?"
    text="We're more than a service provider we're your podcast growth partner."
    points={[
      {
        icon: "shield",
        title: "Consistent Quality",
        description: "Every episode is professionally refined to ensure clear audio, polished delivery, and a premium listener experience.",
      },
      {
        icon: "check-circle",
        title: "Time-Saving Workflow",
        description: "We handle editing, publishing, and distribution so you can focus on creating great content.",
      },
      {
        icon: "zap",
        title: "Fast Turnaround",
        description: "Episodes delivered within 24-48 hours without compromising on quality or attention to detail.",
      },
      {
        icon: "users",
        title: "Dedicated Support",
        description: "Your personal podcast manager ensures smooth communication and quick revisions whenever needed.",
      },
      {
        icon: "award",
        title: "Growth-Focused Strategy",
        description: "SEO-optimized show notes, episode titles, and distribution to maximize your audience reach.",
      },
      {
        icon: "star",
        title: "Transparent Pricing",
        description: "Simple, flat-rate pricing with no hidden fees. Know exactly what you're paying for every month.",
      },
    ]}
    cta={{
      title: "Book a Call",
      url: "#",
    }}
  />

  <StepsTimeline
    title="How it works"
    items={[
      {
        title: "Share Your Episode",
        text: "Send us your raw recordings, notes, and requirements through our simple submission process.",
      },
      {
        title: "We Produce & Optimize",
        text: "Our team edits, enhances audio, prepares content assets, and gets everything ready for publishing.",
      },
      {
        title: "Publish & Distribute",
        text: "Your episode is published and distributed across major podcast platforms for maximum reach.",
      },
      {
        title: "Promote & Grow",
        text: "We repurpose content, support marketing efforts, and help your podcast attract more listeners over time.",
      },
    ]}
  />

  <GalleryText
    title="Designed for teams that value clarity and speed"
    text="A clean interface, powerful features, and thoughtful details come together to help your team move faster—without sacrificing quality."
    cta={{
      title: "Try It Today",
      url: "#",
    }}
    images={[
      {
        alt: "Dashboard overview",
        src: "/image-1.jpg",
        width: 6000,
        height: 4000,
      },
      {
        alt: "Project collaboration view",
        src: "/image-2.jpg",
        width: 2689,
        height: 4032,
      },
      {
        alt: "Analytics and reporting",
        src: "/image-3.jpg",
        width: 3734,
        height: 5359,
      },
    ]}
    marqueeTexts={[
      "Creative Firepower",
      "Built for Speed",
      "Trusted by Professionals",
      "Simple, Transparent Pricing",
    ]}
  />

  <Statements
    items={[
      {
        title: "For modern teams",
        text: "Every feature is designed to reduce complexity and maximize execution speed.",
      },
      {
        title: "Scales as you grow",
        text: "Whether you’re a solo creator or a global team, the platform adapts to your workflow.",
      },
      {
        title: "Real outcomes",
        text: "Less busywork, more progress—so you can deliver meaningful results consistently.",
      },
    ]}
  />

  <TextMarquee
    class="marquee"
    texts={[
      "Creative Firepower",
      "Built for Speed",
      "Trusted by Professionals",
      "Simple, Transparent Pricing",
    ]}
  />

  <Plans
    title="Plans & Pricing"
    subtitle="Start for free, upgrade when you’re ready. No hidden fees, no long-term commitments."
    items={[
      {
        title: "Free Plan",
        price: {
          amount: "$0",
          duration: "month",
        },
        link: {
          title: "Get Started Free",
          url: "#",
        },
        features: [
          { title: "Up to 50 accounts" },
          { title: "Unlimited projects" },
          { title: "Chat support", disabled: true },
          { title: "Email support", disabled: true },
          { title: "Custom onboarding", disabled: true },
        ],
      },
      {
        title: "Premium Plan",
        price: {
          amount: "$20",
          duration: "month",
        },
        link: {
          title: "Start 14-Day Trial",
          url: "#",
        },
        features: [
          { title: "Up to 50 accounts" },
          { title: "Unlimited projects" },
          { title: "Priority chat support" },
          { title: "Email support" },
          { title: "Custom onboarding assistance" },
        ],
      },
    ]}
  />

  <Faqs
    title="Frequently Asked Questions"
    mobileTitle="FAQs"
    subtitle="Quick answers to the most common questions."
    items={[
      {
        question: "Who is this platform for?",
        answer:
          "It’s built for creators, startups, agencies, and teams who want to move faster without sacrificing quality or control.",
      },
      {
        question: "Can I upgrade or downgrade at any time?",
        answer:
          "Yes. You can change plans whenever you need, with no penalties or long-term contracts.",
      },
      {
        question: "Does the free plan really cost nothing?",
        answer:
          "Absolutely. The free plan gives you full access to core features so you can evaluate the platform with confidence.",
      },
      {
        question: "Is my data secure?",
        answer:
          "Yes. We use industry-standard security practices to protect your data and ensure reliability.",
      },
      {
        question: "Do you offer support during onboarding?",
        answer:
          "Premium users receive guided onboarding and priority support to ensure a smooth start.",
      },
    ]}
  />

  <ImageMarquee
    images={[
      {
        src: logo1.src,
        alt: "Logo 1",
      },
      {
        src: logo3.src,
        alt: "Logo 3",
      },
      {
        src: logo4.src,
        alt: "Logo 4",
      },
      {
        src: logo8.src,
        alt: "Logo 8",
      },
      {
        src: logo5.src,
        alt: "Logo 5",
      },
      {
        src: logo6.src,
        alt: "Logo 6",
      },
      {
        src: logo2.src,
        alt: "Logo 2",
      },
      {
        src: logo7.src,
        alt: "Logo 7",
      },
    ]}
  />

  <GL />
  <GLPlaces />
</Layout>

<style>
  .marquee {
    padding: 2rem 0;
    z-index: 9;
  }
</style>
