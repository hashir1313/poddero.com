---
import Layout from "../layouts/Layout.astro";
import HeroHome from "../components/HeroHome.astro";
import TextMarquee from "../components/TextMarquee.astro";
import Services from "../components/Services.astro";
import ImageMarquee from "../components/ImageMarquee.astro";
import Faqs from "../components/Faqs.astro";
import StepsTimeline from "../components/StepsTimeline.astro";
import ContactForm from "../components/ContactForm.astro";
import ValuePropositions from "../components/ValuePropositions.astro";
import WhyChoseUs from "../components/WhyChoseUs.astro";
import GL from "../components/GL.astro";
import GLPlaces from "../components/GlPlaces.astro";

import logo1 from "../assets/logoipsum-344.svg";
import logo2 from "../assets/logoipsum-350.svg";
import logo3 from "../assets/logoipsum-345.svg";
import logo4 from "../assets/logoipsum-385.svg";
import logo5 from "../assets/logoipsum-375.svg";
import logo6 from "../assets/logoipsum-378.svg";
import logo7 from "../assets/logoipsum-346.svg";
import logo8 from "../assets/logoipsum-331.svg";
---

<Layout title="Home">
  <HeroHome
    title="Launch, Grow, Scale"
    subtitle="From professional editing and publishing to distribution and marketing, We handle it all."
    cta={{
      title: "Book a Consultation",
      url: "#",
    }}
  />

  <Services
    secHeading="Services You Will Get"
    subHeading="From production and distribution to audience growth, Podderro provides end-to-end podcast services that help creators save time, maintain quality, and reach more listeners consistently."
    services={[
      {
        title: "Audio Enhancing ",
        text: "Crystal-Clear Audio : Remove background noise, balance audio levels, and enhance sound quality to deliver a professional listening experience.",
        cta: {
          title: "Try It Today",
          url: "#",
        },
        images: [
          {
            alt: "Dashboard overview",
            src: "/image-1.jpg",
            width: 6000,
            height: 4000,
          },
          {
            alt: "Project collaboration view",
            src: "/image-2.jpg",
            width: 2689,
            height: 4032,
          },
          {
            alt: "Analytics and reporting",
            src: "/image-3.jpg",
            width: 3734,
            height: 5359,
          },
        ],
        imagesAlignment: "left",
      },
      {
        title: "Podcast Editing",
        text: "Polished Episodes Ready to Publish : We cut mistakes, tighten conversations, add intros and outros, and prepare each episode for a smooth and engaging listen.",
        cta: {
          title: "Try It Today",
          url: "#",
        },
        images: [
          {
            alt: "Dashboard overview",
            src: "/image-1.jpg",
            width: 6000,
            height: 4000,
          },
          {
            alt: "Project collaboration view",
            src: "/image-2.jpg",
            width: 2689,
            height: 4032,
          },
          {
            alt: "Analytics and reporting",
            src: "/image-3.jpg",
            width: 3734,
            height: 5359,
          },
        ],
        imagesAlignment: "right",
      },
      {
        title: "Content Repurposing",
        text: "Turn One Episode Into Weeks of Content: Transform podcast episodes into short-form videos, social media posts, clips, quotes, and promotional assets that extend your reach.",
        cta: {
          title: "Try It Today",
          url: "#",
        },
        images: [
          {
            alt: "Dashboard overview",
            src: "/image-1.jpg",
            width: 6000,
            height: 4000,
          },
          {
            alt: "Project collaboration view",
            src: "/image-2.jpg",
            width: 2689,
            height: 4032,
          },
          {
            alt: "Analytics and reporting",
            src: "/image-3.jpg",
            width: 3734,
            height: 5359,
          },
        ],
        imagesAlignment: "left",
      },
    ]}
    marqueeTexts={[
      "Creative Firepower",
      "Built for Speed",
      "Trusted by Professionals",
      "Simple, Transparent Pricing",
    ]}
  />

  <WhyChoseUs
    title="Why Choose Podderro?"
    text="We're more than a service provider we're your podcast growth partner."
    points={[
      {
        icon: "shield",
        title: "Consistent Quality",
        description: "Every episode is professionally refined to ensure clear audio, polished delivery, and a premium listener experience.",
      },
      {
        icon: "check-circle",
        title: "Time-Saving Workflow",
        description: "We handle editing, publishing, and distribution so you can focus on creating great content.",
      },
      {
        icon: "zap",
        title: "Fast Turnaround",
        description: "Episodes delivered within 24-48 hours without compromising on quality or attention to detail.",
      },
      {
        icon: "users",
        title: "Dedicated Support",
        description: "Your personal podcast manager ensures smooth communication and quick revisions whenever needed.",
      },
      {
        icon: "award",
        title: "Growth-Focused Strategy",
        description: "SEO-optimized show notes, episode titles, and distribution to maximize your audience reach.",
      },
      {
        icon: "star",
        title: "Transparent Pricing",
        description: "Simple, flat-rate pricing with no hidden fees. Know exactly what you're paying for every month.",
      },
    ]}
    cta={{
      title: "Book a Call",
      url: "#",
    }}
  />

  <StepsTimeline
    title="How it works"
    items={[
      {
        title: "Share Your Episode",
        text: "Send us your raw recordings, notes, and requirements through our simple submission process.",
      },
      {
        title: "We Produce & Optimize",
        text: "Our team edits, enhances audio, prepares content assets, and gets everything ready for publishing.",
      },
      {
        title: "Publish & Distribute",
        text: "Your episode is published and distributed across major podcast platforms for maximum reach.",
      },
      {
        title: "Promote & Grow",
        text: "We repurpose content, support marketing efforts, and help your podcast attract more listeners over time.",
      },
    ]}
  />

  <ValuePropositions
    items={[
      {
        title: "For modern teams",
        text: "Every feature is designed to reduce complexity and maximize execution speed.",
      },
      {
        title: "Scales as you grow",
        text: "Whether you’re a solo creator or a global team, the platform adapts to your workflow.",
      },
      {
        title: "Real outcomes",
        text: "Less busywork, more progress—so you can deliver meaningful results consistently.",
      },
    ]}
  />

  
  <TextMarquee
  class="marquee"
  texts={[
    "Creative Firepower",
    "Built for Speed",
    "Trusted by Professionals",
    "Simple, Transparent Pricing",
  ]}
  />
  
  <Faqs
    title="Frequently Asked Questions"
    mobileTitle="FAQs"
    subtitle="Quick answers to the most common questions."
    items={[
      {
        question: "What podcast services do you provide?",
        answer:
          "We offer podcast editing, audio enhancement, content repurposing, guest booking, distribution, and marketing support.",
      },
      {
        question: "Which podcast platforms do you support?",
        answer:
          "We help distribute podcasts to major platforms including Spotify, Apple Podcasts, YouTube, Amazon Music, and more.",
      },
      {
        question: "How long does it take to deliver an episode?",
        answer:
          "Turnaround times vary by project scope, but most episodes are delivered within a few business days.",
      },
      {
        question: "Do I keep full ownership of my content?",
        answer:
          "Yes. You retain complete ownership of your podcast, recordings, and all published content.",
      },
      {
        question: "Can you work with an existing podcast?",
        answer:
          "Absolutely. Whether you're launching a new show or improving an established one, our services can be tailored to your needs.",
      },
    ]}
  />

<ContactForm
    title="Get In Touch"
    subtitle="Have a question or ready to start? Send us a message and we'll get back to you within 24 hours."
  />


  <ImageMarquee
    images={[
      {
        src: logo1.src,
        alt: "Logo 1",
      },
      {
        src: logo3.src,
        alt: "Logo 3",
      },
      {
        src: logo4.src,
        alt: "Logo 4",
      },
      {
        src: logo8.src,
        alt: "Logo 8",
      },
      {
        src: logo5.src,
        alt: "Logo 5",
      },
      {
        src: logo6.src,
        alt: "Logo 6",
      },
      {
        src: logo2.src,
        alt: "Logo 2",
      },
      {
        src: logo7.src,
        alt: "Logo 7",
      },
    ]}
  />

  <GL />
  <GLPlaces />
</Layout>

<style>
  .marquee {
    padding: 2rem 0;
    z-index: 9;
  }
</style>
