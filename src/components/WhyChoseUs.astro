---
import Button from "../components/Button.astro";
import type { Link } from "../types";
import { Shield, CheckCircle, Zap, Users, Award, Star } from "@lucide/astro";

interface Point {
  icon: "shield" | "check-circle" | "zap" | "users" | "award" | "star";
  title: string;
  description: string;
}

interface Props {
  title: string;
  text: string;
  points: Point[];
  cta?: Link;
}

const { title, text, points, cta } = Astro.props;

const icons = {
  shield: Shield,
  "check-circle": CheckCircle,
  zap: Zap,
  users: Users,
  award: Award,
  star: Star,
};
---

<div class="sy-introducing">
  <div class="u-container container">
    <div class="inner">
      <h2 class="u-heading title" data-sy-reveal="words">{title}</h2>
      <p class="u-text" data-sy-reveal="lines">
        {text}
      </p>
      <div class="points">
        {points.map((point) => {
          const Icon = icons[point.icon];
          return (
            <div class="point">
              <div class="point-inner">
                <Icon stroke-width={2} size={30} />
                <div class="content">
                  <h3 class="u-heading point-title">{point.title}</h3>
                  <p class="u-text point-text">{point.description}</p>
                </div>
              </div>
            </div>
          );
        })}
      </div>
      {cta ? <Button {...cta} arrow class="cta" /> : null}
      <div data-gl-place></div>
    </div>
  </div>
</div>

<style>
  .container {
    margin-top: 8rem;
    margin-bottom: 8rem;
    position: relative;
  }

  .inner {
    position: relative;
    z-index: 9;
    max-width: 50rem;
    margin: 0 auto;
    padding: 1rem;
    text-align: center;
    gap: 1rem;
    display: flex;
    justify-content: center;
    align-items: center;
    flex-direction: column;
    border-radius: 1.5rem;
    backdrop-filter: blur(6px) saturate(1.05);
  }

  h2 {
    --fs: 3rem;
    --lh: 1.1;
    max-width: 20em;
  }

  p {
    max-width: 40em;
  }

  [data-gl-place] {
    --d: 0.1;
    --s: 18rem;
    position: absolute;
    right: 0%;
    top: 0;
    margin-top: -2rem;

    @media (--mq-tablet-sm) {
      transform: translateX(-10%);
      left: 0;
    }
  }


  .points {
    width: 100%;
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
    justify-content: center;
    margin: 2rem 0;
  }

  .point {
    width: 45%;
    min-width: 280px;
  }

  .point-inner {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 1rem;
  }

  .content {
    width: 100%;
    text-align: start;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .point-title {
    margin: 0;
    --fs: 1.25rem;
    --fw: 500;
    --lh: 1.3;
  }

  .point-text {
    margin: 0;
    --fs: 0.95rem;
    --lh: 1.5;
    color: var(--text-muted);
  }

  @media (--mq-tablet) {
    .points {
      gap: 1.5rem;
    }

    .point {
      width: 100%;
      min-width: 0;
    }

    .point-inner {
      gap: 1rem;
    }
  }

  @media (--mq-phone) {
    .points {
      gap: 1rem;
      margin: 1.5rem 0;
    }

    .point-inner {
      gap: 0.75rem;
    }

    .content h3 {
      font-size: 1.1rem;
    }

    .content p {
      font-size: 0.9rem;
    }
  }
</style>
