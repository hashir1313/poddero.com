---
interface Props {
  title: string;
  subtitle: string;
}

const { title, subtitle } = Astro.props;
---

<div class="sy-plans">
  <div class="u-container">

    <h2 class="u-heading title" data-sy-reveal="words">{title}</h2>
    <p class="u-text subtitle" data-sy-reveal="lines">{subtitle}</p>

    <div class="contact-card">
      <div class="card-inner">
        <form class="contact-form" id="contact-form">
          <div class="form-group">
            <label for="name" class="u-text">Name</label>
            <input type="text" id="name" name="name" placeholder="Your name" required />
          </div>
          <div class="form-group">
            <label for="email" class="u-text">Email</label>
            <input type="email" id="email" name="email" placeholder="your@email.com" required />
          </div>
          <div class="form-group">
            <label for="subject" class="u-text">Subject</label>
            <input type="text" id="subject" name="subject" placeholder="How can we help?" />
          </div>
          <div class="form-group">
            <label for="message" class="u-text">Message</label>
            <textarea id="message" name="message" rows="5" placeholder="Tell us about your project..." required></textarea>
          </div>
          <button type="submit" class="submit-btn">
            Send Message
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </button>
        </form>
      </div>
    </div>
  </div>
</div>

<style>
  .sy-plans {
    margin: 2rem 0;
    position: relative;
    z-index: 2;
  }

  .title {
    --fs: 3rem;
    text-align: center;
    text-transform: uppercase;
    margin-bottom: 0.1em;
  }

  .subtitle {
    --fs: var(--font-size-md);
    color: var(--color-text-alt);
    max-width: 32em;
    text-align: center;
    margin: 0 auto 2em;
  }

  .contact-card {
    max-width: 32rem;
    width: 100%;
    margin: 0 auto;
    border-radius: 1rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
    position: relative;
    padding: 2px;
    background: linear-gradient(
      135deg,
      var(--color-brand-3) 0%,
      var(--color-brand-1) 100%
    );
    overflow: hidden;
  }

  .card-inner {
    background: var(--color-white);
    border-radius: 0.9rem;
    padding: 2.5rem;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .form-group label {
    --fs: var(--font-size-sm);
    --fw: 500;
    color: var(--color-text);
  }

  .form-group input,
  .form-group textarea {
    width: 100%;
    padding: 0.875rem 1rem;
    border: 1px solid var(--color-border, #e2e8f0);
    border-radius: 0.5rem;
    font-family: inherit;
    font-size: var(--font-size-sm);
    color: var(--color-text);
    background: var(--color-bg, #fafafa);
    transition: border-color 0.2s ease, box-shadow 0.2s ease;

    &::placeholder {
      color: var(--color-text-alt, #94a3b8);
    }

    &:focus {
      outline: none;
      border-color: var(--color-brand-1);
      box-shadow: 0 0 0 3px rgba(var(--color-brand-1-rgb, 99, 102, 241), 0.1);
    }
  }

  .form-group textarea {
    resize: vertical;
    min-height: 100px;
  }

  .submit-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.875rem 2rem;
    background: var(--color-brand-1);
    color: var(--color-white);
    border: none;
    border-radius: 0.5rem;
    font-family: inherit;
    font-size: var(--font-size-sm);
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s ease, transform 0.2s ease;

    &:hover {
      background: var(--color-brand-2);
      transform: translateY(-1px);
    }

    &:active {
      transform: translateY(0);
    }
  }

  @media (--mq-phone) {
    .card-inner {
      padding: 1.5rem;
    }
  }
</style>
