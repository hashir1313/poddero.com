---
import type { Link, Image } from "../types";
import Button from "./Button.astro";
import Gallery from "./Gallery.astro";

interface Props {
  images: Image[];
  title: string;
  text?: string;
  cta?: Link;
  imagesAlignment: "left" | "right";
}

const { title, text, cta, images, imagesAlignment } = Astro.props;
---

<div class={"gallery-text " + imagesAlignment}>
  <div class="content">
    <h2 class="u-heading title" data-sy-reveal="words">{title}</h2>
    <p class="u-text text" data-sy-reveal="lines">{text}</p>
    {cta ? <Button {...cta} arrow class="cta" /> : null}
  </div>
  <Gallery class="gallery" images={images} />
</div>

<style>
  .gallery-text {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 3rem;
    position: relative;
    z-index: 9;
    padding: 2rem;
    border-radius: 1.5rem;
    backdrop-filter: blur(6px) saturate(1.05);

    @media (--mq-tablet) {
      gap: 2rem;
    }

    @media (--mq-tablet-sm) {
      flex-direction: column-reverse;
    }

    @media (--mq-phone) {
      padding: 1rem 0;
    }
  }

  .left {
    flex-direction: row-reverse;
  }

  .right {
    flex-direction: row;
  }

  .content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding: 1rem 0;
    flex: 1;
  }

  .title {
    --fs: 2rem;
    --fw: 600;
    --lh: 1;
    max-width: 10em;
    margin-bottom: 1rem;
  }

  .text {
    max-width: 25em;
  }

  .cta {
    margin-top: 1.5rem;
  }

  .gallery {
    max-width: 32rem;
    min-height: 22rem;

    @media (--mq-desktop-sm) {
      max-width: 27rem;
    }

    @media (--mq-tablet) {
      max-width: 25rem;
    }
  }
</style>
